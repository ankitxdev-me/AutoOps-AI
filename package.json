{
  "name": "autoops-ai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "prepare": "husky",
    "build:api": "pnpm exec prisma generate && pnpm --filter api build",
    "start:api": "node apps/api/dist/main.js"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "prisma": "^6.2.1",
    "turbo": "^2.10.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "packageManager": "pnpm@11.10.0",
  "dependencies": {
    "@prisma/client": "6.19.3"
  }
}
