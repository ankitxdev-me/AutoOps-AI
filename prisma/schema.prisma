datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model SchemaVerification {
  id        String   @id @default(uuid())
  verified  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Tenant {
  id             String           @id @default(uuid())
  name           String
  slug           String           @unique
  industry       String
  country        String
  status         String           @default("onboarding_pending")
  plan           String           @default("free")
  onboardingStep String           @default("1")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?

  employees      Employee[]
  profile        BusinessProfile?
}

model User {
  id        String     @id @default(uuid())
  clerkId   String     @unique
  email     String     @unique
  firstName String?
  lastName  String?
  avatarUrl String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  employees Employee[]
}

enum EmployeeRole {
  OWNER
  ADMIN
  MEMBER
}

model Employee {
  id        String       @id @default(uuid())
  tenantId  String
  userId    String
  role      EmployeeRole @default(MEMBER)
  status    String       @default("active")
  title     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
}

model BusinessProfile {
  id                  String   @id @default(uuid())
  tenantId            String   @unique
  legalBusinessName   String
  displayName         String
  businessEmail       String?
  phoneNumber         String?
  website             String?
  industry            String
  businessDescription String?
  country             String
  state               String?
  city                String?
  addressLine1        String?
  addressLine2        String?
  postalCode          String?
  logoUrl             String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}
